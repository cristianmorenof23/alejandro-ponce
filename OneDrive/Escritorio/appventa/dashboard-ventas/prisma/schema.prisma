generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int        @id @default(autoincrement())
  nombre    String
  email     String     @unique
  password  String
  rol       Rol
  objetivos Objetivo[]
  ventas    Venta[]
}

model Venta {
  id        Int       @id @default(autoincrement())
  categoria Categoria
  monto     Float
  fecha     DateTime  @default(now())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
}

model Objetivo {
  id        Int       @id @default(autoincrement())
  categoria Categoria
  montoMeta Float
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
}

enum Categoria {
  CALZADOS
  ACCESORIOS
  NIÑO
  INDUMENTARIA
}

enum Rol {
  VENDEDOR
  ENCARGADA
}
